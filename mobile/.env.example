# Override the API base URL if running backend on a non-default host
# EXPO_PUBLIC_JAIN_API_URL=http://192.168.1.50:8000

# Google OAuth client IDs (create in Google Cloud Console).
# Set at least the one matching your platform; see plan Task 14 for setup.
#
# iOS (Bundle ID: host.exp.Exponent) — required for iPhone testing in Expo Go
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=your-ios-client-id.apps.googleusercontent.com
#
# Android (Package: host.exp.exponent) — required for Android testing in Expo Go
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=your-android-client-id.apps.googleusercontent.com
#
# Web (for web builds + localhost dev). Optional if you only target mobile.
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your-web-client-id.apps.googleusercontent.com
